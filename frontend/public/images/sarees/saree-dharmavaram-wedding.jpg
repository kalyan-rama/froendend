<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 1000" width="800" height="1000">
    <defs>
      <!-- Base Silk Gradient -->
      <linearGradient id="silk-grad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#1F7B85" />
        <stop offset="30%" stop-color="#1F7B85" stop-opacity="0.95" />
        <stop offset="50%" stop-color="#ffffff" stop-opacity="0.15" />
        <stop offset="70%" stop-color="#1F7B85" stop-opacity="0.95" />
        <stop offset="100%" stop-color="#1F7B85" />
      </linearGradient>
      
      <!-- Border Gradient -->
      <linearGradient id="border-grad" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#D38F24" />
        <stop offset="50%" stop-color="#E5C158" />
        <stop offset="100%" stop-color="#D38F24" />
      </linearGradient>

      <!-- Royal Zari Pattern Gold -->
      <pattern id="zari-peacock" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M20 5 L35 20 L20 35 L5 20 Z" fill="none" stroke="#E5C158" stroke-width="1" opacity="0.3"/>
        <circle cx="20" cy="20" r="3" fill="#E5C158" opacity="0.5"/>
      </pattern>

      <!-- Diagonal Threads Grid -->
      <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M 40 0 L 0 40 M 0 0 L 40 40" fill="none" stroke="#000" stroke-width="0.5" opacity="0.08"/>
      </pattern>
    </defs>

    <!-- Silk Body Base -->
    <rect width="100%" height="100%" fill="url(#silk-grad)" />
    <!-- Diagonal Checks Overlay -->
    <rect width="100%" height="100%" fill="url(#grid)" />
    
    <!-- Heavy zari bootis (Peacock or Paisley theme) in body -->
    <g opacity="0.75">
      <rect width="100%" height="100%" fill="url(#zari-peacock)" />
    </g>

    <!-- Side Traditional Zari Borders -->
    <!-- Left Border -->
    <rect x="0" y="0" width="80" height="1000" fill="url(#border-grad)" />
    <!-- Right Border -->
    <rect x="720" y="0" width="80" height="1000" fill="url(#border-grad)" />

    <!-- Pure Silk Authentic Label Shield -->
    <g transform="translate(400, 500)">
      <!-- Backdrop Shield -->
      <rect x="-180" y="-120" width="360" height="240" rx="16" fill="#1A1813" fill-opacity="0.85" stroke="#E5C158" stroke-width="3" />
      <rect x="-172" y="-112" width="344" height="224" rx="12" fill="none" stroke="#E5C158" stroke-width="1" stroke-dasharray="6,4" />
      
      <!-- Logo Motif -->
      <path d="M0 -70 L15 -45 L35 -45 L15 -25 L25 5 L0 -15 L-25 5 L-15 -25 L-35 -45 L-15 -45 Z" fill="#E5C158" opacity="0.9"/>
      
      <!-- Text details -->
      <text y="25" text-anchor="middle" font-family="'Cinzel', 'Playfair Display', 'Times New Roman', serif" font-size="15" fill="#FFFFFF" letter-spacing="3" font-weight="bold">
        SREE PRAHARSHA
      </text>
      <text y="48" text-anchor="middle" font-family="'Cinzel', 'Playfair Display', serif" font-size="11" fill="#E5C158" letter-spacing="4">
        SAREES
      </text>
      
      <text y="80" text-anchor="middle" font-family="'Inter', sans-serif" font-size="9" fill="#D3D3D3" font-weight="300" letter-spacing="1">
         DHARMAVARAM TEMPLE BORDER SILK 
      </text>

      <text y="95" text-anchor="middle" font-family="'JetBrains Mono', monospace" font-size="8" fill="#E5C158" letter-spacing="2">
        100% PURE SILK MARK APPROVED
      </text>
    </g>

    <!-- Bottom Grand Pallu Border -->
    <rect x="80" y="900" width="640" height="100" fill="url(#border-grad)" />
    <path d="M 80 900 Q 400 920 720 900 L 720 1000 L 80 1000 Z" fill="#1A1813" fill-opacity="0.15" />
    
    <!-- Top Pallu border -->
    <rect x="80" y="0" width="640" height="80" fill="url(#border-grad)" />
  </svg>